  # ============================================================================
  # PERSONAL OS AUTHENTICATION
  # ============================================================================
  # Required environment variables for Personal OS authentication.
  # All three must be set in Vercel for the auth system to work.

  # PERSONAL_ALLOWED_EMAILS
  # Comma-separated list of email addresses allowed to access Personal OS.
  # Example: you@example.com,backup@gmail.com
  # PERSONAL_ALLOWED_EMAILS=

  # PERSONAL_GATE_SECRET
  # Secret key used to sign the personal_os_gate HttpOnly cookie via HMAC-SHA256.
  # Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
  # PERSONAL_GATE_SECRET=

  # PERSONAL_SECOND_PASSWORD_HASH
  # scrypt hash of the second password, in format: scrypt:<salt>:<hash>
  # Generate with: node -e "const c=require('crypto'); c.scrypt('your-password','your-salt',32,(e,k)=>{console.log('scrypt:your-salt:'+k.toString('hex'))})"
  # PERSONAL_SECOND_PASSWORD_HASH=

  # Legacy dashboard password (kept for backward compatibility)
  # DASHBOARD_PASSWORD=00000008

  # ============================================================================
  # MESSAGE STORAGE (OPTIONAL - for production use)
  # ============================================================================
  # Choose ONE of the following storage backends for messages:
  # - Upstash Redis (recommended for production)
  # - Vercel KV (alternative option)
  # - Local file (default for development, no setup needed)

  # Option 1: Upstash Redis (Recommended)
  # Get your credentials from: https://upstash.com/
  # UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
  # UPSTASH_REDIS_REST_TOKEN=your_upstash_token

  # Option 2: Vercel KV (Alternative)
  # Get your credentials from: https://vercel.com/storage/kv
  # KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
  # KV_REST_API_TOKEN=your_kv_token

  # ============================================================================
  # MESSAGE ENCRYPTION (OPTIONAL - for production use)
  # ============================================================================
  # Generate a secure encryption key for message data
  # Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
  # MESSAGE_ENCRYPTION_KEY=your_secure_encryption_key_here

  # ============================================================================
  # EMAIL NOTIFICATIONS (OPTIONAL - for sending emails on contact form submission)
  # ============================================================================
  # Get your credentials from: https://resend.com/
  RESEND_API_KEY=re_fDWak8DG_A9kVoTm4rAThVq47qyciWaJ8
  RESEND_FROM_EMAIL=onboarding@resend.dev
  RESEND_FROM_NAME=Oussama Lassoued
  CONTACT_EMAIL_TO=work.oussama.lassoued@gmail.com

  # ============================================================================
  # NOTES
  # ============================================================================
  # - For local development: No additional setup needed (uses local file storage)
  # - For production: Set up Upstash Redis or Vercel KV for persistent storage
  # - For email notifications: Configure Resend API key and email settings
  # - All variables are optional - system works with defaults
  # - Copy this file to .env and update values as needed
