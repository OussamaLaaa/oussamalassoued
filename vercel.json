{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": "vite",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "functions": {
    "api/documents.js": {
        "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/opportunities",
      "dest": "/api/opportunities.js"
    },
    {
      "src": "/api/site/config",
      "dest": "/api/site/config.js"
    },
    {
      "src": "/api/site/media/upload",
      "dest": "/api/site/media/upload.js"
    },
    {
      "src": "/api/site/backup",
      "dest": "/api/site/backup.js"
    },
    {
      "src": "/api/site/restore",
      "dest": "/api/site/restore.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/videos/(.*)",
      "dest": "/videos/$1"
    },
    {
      "src": "/frames/(.*)",
      "dest": "/frames/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/frames/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "env": {
    "DASHBOARD_PASSWORD": "00000008"
  }
}